# =============================================================================
# Project TUTORIAL — environment template (copy to .env)
# All variables use the TUTORIAL_ prefix; nested groups use double underscore.
# =============================================================================

# --- LLM ---------------------------------------------------------------------
TUTORIAL_LLM__MODEL_NAME=gpt-4o-mini
TUTORIAL_LLM__API_KEY=replace-me
TUTORIAL_LLM__BASE_URL=https://api.openai.com/v1
TUTORIAL_LLM__TEMPERATURE_AGENTS=0.1
TUTORIAL_LLM__TEMPERATURE_CREATIVE=0.7
TUTORIAL_LLM__MAX_TOKENS=4096
TUTORIAL_LLM__TIMEOUT_SECONDS=120

# --- Agents ------------------------------------------------------------------
TUTORIAL_AGENTS__MAX_CONCURRENT_AGENTS=8
TUTORIAL_AGENTS__RETRY_ATTEMPTS=3
TUTORIAL_AGENTS__RETRY_BACKOFF_SECONDS=2.0
# JSON map of agent_name -> partial override dict merged into agent defaults
TUTORIAL_AGENTS__PER_AGENT_OVERRIDES_JSON={}

# --- Security integrations ---------------------------------------------------
# Paths validated at startup when set (leave empty in dev to skip file checks)
TUTORIAL_SECURITY__SIFT_WORKSTATION_PATH=
TUTORIAL_SECURITY__SPLUNK_HOST=https://splunk.example.com:8089
TUTORIAL_SECURITY__SPLUNK_TOKEN=
TUTORIAL_SECURITY__VOLATILITY_PATH=

# --- Education ---------------------------------------------------------------
TUTORIAL_EDUCATION__CSTA_STANDARDS_PATH=
TUTORIAL_EDUCATION__DIFFICULTY_LEVELS=5
TUTORIAL_EDUCATION__MIN_LESSON_DURATION_SECONDS=300

# --- Database ----------------------------------------------------------------
TUTORIAL_DATABASE__URL=sqlite+aiosqlite:///./tutorial.db
TUTORIAL_DATABASE__POOL_SIZE=5
TUTORIAL_DATABASE__ECHO=false

# --- Message bus -------------------------------------------------------------
TUTORIAL_MESSAGE_BUS__MAX_QUEUE_SIZE=10000
TUTORIAL_MESSAGE_BUS__MESSAGE_TTL_SECONDS=3600

# --- State machine checkpoints -----------------------------------------------
TUTORIAL_STATE_MACHINE__CHECKPOINT_PATH=./state_checkpoints.sqlite

# --- MCP (Model Context Protocol) --------------------------------------------
# JSON array of {name, command, args[], env?, cwd?} stdio server definitions
TUTORIAL_MCP__SERVERS_JSON=[]
TUTORIAL_MCP__REGISTRY_CACHE_PATH=./mcp_registry.sqlite
TUTORIAL_MCP__TOOL_CALL_TIMEOUT_SECONDS=60
TUTORIAL_MCP__MAX_CONNECTIONS_PER_SERVER=5
TUTORIAL_MCP__HEALTH_INTERVAL_SECONDS=30
TUTORIAL_MCP__PING_ENABLED=true

# --- Logging -----------------------------------------------------------------
TUTORIAL_LOGGING__CONFIG_PATH=config/logging_config.yaml
TUTORIAL_LOGGING__SERVICE_NAME=tutorial

# --- HTTP API (FastAPI) --------------------------------------------------------
TUTORIAL_API__DEMO_API_KEY=tutorial-demo-key
TUTORIAL_API__RATE_LIMIT_PER_MINUTE=100
TUTORIAL_API__EVIDENCE_UPLOAD_DIR=var/evidence_uploads
TUTORIAL_API__WS_POLL_SECONDS=18
